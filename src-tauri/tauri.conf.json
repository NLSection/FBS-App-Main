{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FBS",
  "version": "0.1.0",
  "identifier": "nl.fbs.app",
  "build": {
    "frontendDist": "http://localhost:3000",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FBS - Financieel Beheer Systeem",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Section Labs",
    "externalBin": ["node"],
    "resources": [
      "app/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
