{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FBS",
  "version": "0.1.5",
  "identifier": "nl.fbs.app",
  "build": {
    "frontendDist": "http://localhost:3001",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FBS - Financieel Beheer Systeem",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc5MzI0RENGMTg4RTYyMDEKUldRQllvNFl6MDB5ZVdqZVNFaXZwZ0kySkUxZy83ZFo2U1R5SUcwUnRXendlOFRZNWtzU2MzeEsK",
      "endpoints": ["https://fbs-update-worker.section-labs.workers.dev/tauri"],
      "windows": { "installerArgs": ["/S"], "installMode": "passive" }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Section Labs",
    "externalBin": ["node"],
    "resources": [
      "app/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
